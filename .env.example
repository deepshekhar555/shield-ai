# ═══════════════════════════════════════════════════════════════
#  Shield AI v2.0 — Environment Configuration
#  HOW TO USE:
#    1. Copy this file:  copy .env.example .env
#    2. Fill in your real Razorpay keys (see instructions below)
#    3. NEVER push .env to GitHub (it's in .gitignore)
# ═══════════════════════════════════════════════════════════════

# ── HOW TO GET RAZORPAY TEST KEYS (FREE — No real money) ────────
#
#  STEP 1: Go to  https://dashboard.razorpay.com/signup
#           Create a free account (no KYC needed for test mode)
#
#  STEP 2: After login → top-right toggle → switch to "Test Mode"
#
#  STEP 3: Go to:  Settings → API Keys → Generate Test Key
#           You will see:
#             Key Id:     rzp_test_XXXXXXXXXXXX  ← copy this
#             Key Secret: YYYYYYYYYYYYYYYY        ← copy ONCE (shown only once)
#
#  STEP 4: Go to:  Settings → Webhooks → Add New Webhook
#           URL:    https://your-app.railway.app/razorpay/webhook
#           Secret: make up any random string (e.g. Shield_Webhook_2026)
#           Events: check  payment.captured  AND  payment.failed
#
#  STEP 5: Paste all three values below and save

# ── Razorpay Credentials ────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOURS
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ── Server Config ───────────────────────────────────────────────
# Railway.app sets PORT automatically — do not change this
PORT=8000
HOST=0.0.0.0

# ── HOW TO LOAD THIS IN PYTHON ──────────────────────────────────
# The app.py uses os.getenv() which reads from environment.
# To load .env locally, either:
#   Option A: pip install python-dotenv
#             then in app.py: from dotenv import load_dotenv; load_dotenv()
#   Option B: On Railway.app → go to Variables tab → add each key manually
